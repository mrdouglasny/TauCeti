import Mathlib.GroupTheory.Schreier
import Mathlib.Tactic

/-!
# The index of powers in a finitely generated commutative group

In a commutative group generated by a finite set `S`, the range of the `n`th-power homomorphism
has index at most `n ^ S.card` when `n` is nonzero. In particular, the range of the squaring
homomorphism has index at most `2 ^ S.card`.

## Main results

* `TauCeti.index_powMonoidHom_range_le_of_closure_eq_top`: `[G : GвҒҝ] вүӨ n ^ S.card`.
* `TauCeti.index_powMonoidHom_two_range_le_of_closure_eq_top`: `[G : GВІ] вүӨ 2 ^ S.card`.

## Provenance

The argument is migrated from
[kim-em/erdos-unit-distance](https://github.com/kim-em/erdos-unit-distance), where it was an
abstract step towards bounding the index of squares in the unit group of a number field.
-/

namespace TauCeti

/-- In a commutative group generated by a finite set `S`, the range of `powMonoidHom n` has
index at most `n ^ S.card` when `n` is nonzero. This applies Mathlib's exponent/rank cardinality
bound to the quotient by the `n`th powers. -/
theorem index_powMonoidHom_range_le_of_closure_eq_top {G : Type*} [CommGroup G]
    {S : Finset G} {n : в„•} (hn : n вү  0) (hS : Subgroup.closure (S : Set G) = вҠӨ) :
    (powMonoidHom n : G вҶ’* G).range.index вүӨ n ^ S.card := by
  classical
  set H := (powMonoidHom n : G вҶ’* G).range with hH
  haveI : Group.FG G := Group.fg_iff'.mpr вҹЁS.card, S, rfl, hSвҹ©
  haveI : Group.FG (G в§ё H) := Group.fg_of_surjective (QuotientGroup.mk'_surjective H)
  have hpow : вҲҖ q : G в§ё H, q ^ n = 1 := fun q =>
    QuotientGroup.induction_on q fun g => by
      rw [вҶҗ QuotientGroup.mk_pow, QuotientGroup.eq_one_iff]
      exact вҹЁg, rflвҹ©
  have hcard : Nat.card (G в§ё H) вҲЈ n ^ Group.rank (G в§ё H) :=
    card_dvd_exponent_pow_rank' (G в§ё H) hpow
  have hrank : Group.rank (G в§ё H) вүӨ S.card :=
    (Group.rank_le_of_surjective (QuotientGroup.mk' H) (QuotientGroup.mk'_surjective H)).trans
      (Group.rank_le hS)
  calc (powMonoidHom n : G вҶ’* G).range.index
      = Nat.card (G в§ё H) := rfl
    _ вүӨ n ^ Group.rank (G в§ё H) := Nat.le_of_dvd (pow_pos (Nat.pos_of_ne_zero hn) _) hcard
    _ вүӨ n ^ S.card := Nat.pow_le_pow_right (Nat.pos_of_ne_zero hn) hrank

/-- In a commutative group generated by a finite set `S`, the range of the squaring
homomorphism `powMonoidHom 2` has index at most `2 ^ S.card`. The quotient by the squares is
an elementary abelian `2`-group spanned by the image of `S`. -/
theorem index_powMonoidHom_two_range_le_of_closure_eq_top {G : Type*} [CommGroup G]
    {S : Finset G} (hS : Subgroup.closure (S : Set G) = вҠӨ) :
    (powMonoidHom 2 : G вҶ’* G).range.index вүӨ 2 ^ S.card :=
  index_powMonoidHom_range_le_of_closure_eq_top (by norm_num) hS

end TauCeti
