import Mathlib.GroupTheory.Index
import Mathlib.GroupTheory.QuotientGroup.Basic
import Mathlib.Tactic

/-!
# The index of squares in a finitely generated commutative group

In a commutative group generated by a finite set `S`, the range of the squaring homomorphism
has index at most `2 ^ S.card`: the quotient by the squares is an elementary abelian
`2`-group spanned by the image of `S`, so it has at most `2 ^ S.card` elements.

## Main results

* `TauCeti.index_range_powMonoidHom_two_le_of_closure_eq_top`: `[G : G²] ≤ 2 ^ S.card`.

## Provenance

The argument is migrated from
[kim-em/erdos-unit-distance](https://github.com/kim-em/erdos-unit-distance), where it was an
abstract step towards bounding the index of squares in the unit group of a number field.
-/

namespace TauCeti

/-- For an element of order dividing two, an integer power depends only on the exponent
modulo two. -/
private theorem zpow_eq_zpow_emod_two {G : Type*} [Group G] {x : G} (hx : x ^ 2 = 1) (z : ℤ) :
    x ^ z = x ^ (z % 2) := by
  have hx2 : x ^ (2 : ℤ) = 1 := by exact_mod_cast hx
  have heven : x ^ (2 * (z / 2)) = 1 := by rw [zpow_mul, hx2, one_zpow]
  have hz : x ^ z = x ^ (2 * (z / 2)) * x ^ (z % 2) := by
    rw [← zpow_add]; congr 1; omega
  rw [hz, heven, one_mul]

/-- In a commutative group generated by a finite set `S`, the range of the squaring
homomorphism `powMonoidHom 2` has index at most `2 ^ S.card`. The quotient by the squares is
an elementary abelian `2`-group spanned by the image of `S`. -/
theorem index_range_powMonoidHom_two_le_of_closure_eq_top {G : Type*} [CommGroup G]
    {S : Finset G} (hS : Subgroup.closure (S : Set G) = ⊤) :
    (powMonoidHom 2 : G →* G).range.index ≤ 2 ^ S.card := by
  classical
  set H := (powMonoidHom 2 : G →* G).range with hH
  set mk : G →* G ⧸ H := QuotientGroup.mk' H with hmk
  -- Every element of `G` is an integer-power product over `S`.
  have hpow : ∀ g : G, ∃ z : S → ℤ, g = ∏ s : S, (s : G) ^ z s := by
    intro g
    have hg : g ∈ Subgroup.closure (S : Set G) := hS ▸ Subgroup.mem_top g
    induction hg using Subgroup.closure_induction with
    | mem x hx =>
        refine ⟨fun s => if s = ⟨x, hx⟩ then 1 else 0, ?_⟩
        rw [Finset.prod_eq_single (⟨x, hx⟩ : S)] <;> simp +contextual
    | one => exact ⟨0, by simp⟩
    | mul x y _ _ hx hy =>
        obtain ⟨zx, rfl⟩ := hx
        obtain ⟨zy, rfl⟩ := hy
        exact ⟨zx + zy, by simp [zpow_add, Finset.prod_mul_distrib]⟩
    | inv x _ hx =>
        obtain ⟨zx, rfl⟩ := hx
        exact ⟨-zx, by simp [zpow_neg, Finset.prod_inv_distrib]⟩
  -- In the quotient each generator has order dividing two.
  have hsq : ∀ s : S, mk (s : G) ^ 2 = 1 := fun s => by
    rw [← map_pow, hmk, QuotientGroup.mk'_apply, QuotientGroup.eq_one_iff]
    exact ⟨(s : G), rfl⟩
  -- Every quotient element is a `{0,1}`-exponent product of the generators.
  have hsurj : Function.Surjective
      (fun f : S → Fin 2 => ∏ s : S, mk (s : G) ^ (f s : ℕ)) := by
    intro q
    obtain ⟨g, rfl⟩ := QuotientGroup.mk'_surjective H q
    obtain ⟨z, rfl⟩ := hpow g
    refine ⟨fun s => ⟨(z s % 2).toNat, by omega⟩, ?_⟩
    rw [hmk, map_prod]
    refine Finset.prod_congr rfl fun s _ => ?_
    rw [map_zpow, ← hmk]
    conv_rhs => rw [zpow_eq_zpow_emod_two (hsq s)]
    rw [← zpow_natCast (mk (s : G)) (z s % 2).toNat,
      Int.toNat_of_nonneg (Int.emod_nonneg _ (by norm_num))]
  calc (powMonoidHom 2 : G →* G).range.index
      = Nat.card (G ⧸ H) := rfl
    _ ≤ Nat.card (S → Fin 2) := Nat.card_le_card_of_surjective _ hsurj
    _ = 2 ^ S.card := by
        rw [Nat.card_eq_fintype_card, Fintype.card_fun, Fintype.card_fin, Fintype.card_coe]

end TauCeti
