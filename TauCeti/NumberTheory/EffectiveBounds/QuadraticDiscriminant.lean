import TauCeti.NumberTheory.EffectiveBounds.Discriminant
import TauCeti.FieldTheory.Trace
import Mathlib.LinearAlgebra.FiniteDimensional.Lemmas

/-!
# The effective discriminant bound for a quadratic field, evaluated on a square-root basis

The effective discriminant bound `|d_K| Ōēż |disc b|`
(`TauCeti.NumberField.abs_discr_le_of_basis_isIntegral`) is only useful once one can
*evaluate* `disc b` on a concrete basis. For a quadratic field generated by a square root,
the cheapest basis is `{1, x}` with `x┬▓ Ōłł ŌäÜ`, and the trace-form discriminant there is
`disc ŌäÜ {1, x} = 4┬Ęx┬▓` (`TauCeti.Algebra.discr_one_elem_eq_of_sq_algebraMap`, the
trace-form diagonalisation). Feeding an *integer* square root `x┬▓ = a Ōłł Ōäż` into the bound
turns these two pieces into a single closed-form estimate

`|d_K| Ōēż 4┬Ę|a|`

for every quadratic field `K = ŌäÜ(x)` with `x┬▓ = a Ōłł Ōäż`. This is precisely the tool the
roadmap's quadratic worked examples need: `ŌäÜ(i)` (`a = -1`) gives `|d_K| Ōēż 4`, and
`ŌäÜ(ŌłÜ-5)` (`a = -5`) gives `|d_K| Ōēż 20`.

The real content beyond the two cited lemmas is the basis construction: a square root `x`
outside `ŌäÜ` makes `{1, x}` linearly independent, and in a quadratic field that family is a
`ŌäÜ`-basis of algebraic integers, so the effective bound applies to it.

## Main results

* `TauCeti.NumberField.abs_discr_le_of_sq_intCast`: `|d_K| Ōēż 4┬Ę|a|` (over `ŌäÜ`) for a
  quadratic field `K` and `x : K` with `x┬▓ = a Ōłł Ōäż` and `x Ōłē ŌäÜ`.
* `TauCeti.NumberField.abs_discr_le_of_sq_intCast'`: the same bound stated entirely over
  `Ōäż`, `|d_K| Ōēż 4┬Ę|a|`.

## Provenance

The two consumed ingredients are migrated from
[kim-em/erdos-unit-distance](https://github.com/kim-em/erdos-unit-distance), the
formalization of L. Alp├Čge's disproof of the uniform-constant Erd┼æs unit-distance
conjecture: the effective discriminant bound and the square-root trace-form
diagonalisation. The closed-form quadratic estimate assembled here is new.
-/

open Module

namespace TauCeti

namespace NumberField

/-- For a quadratic number field `K` and an element `x : K` whose square is an integer
`a` and which is not rational, the field discriminant satisfies `|d_K| Ōēż 4┬Ę|a|`.

The square-root basis `{1, x}` consists of algebraic integers, so the effective bound
`abs_discr_le_of_basis_isIntegral` applies, and the trace-form diagonalisation evaluates
its discriminant as `disc ŌäÜ {1, x} = 4┬Ęa`. -/
theorem abs_discr_le_of_sq_intCast {K : Type*} [Field K] [NumberField K]
    {x : K} {a : Ōäż} (hfin : finrank ŌäÜ K = 2)
    (hx2 : x ^ 2 = algebraMap Ōäż K a) (hx : x Ōłē (algebraMap ŌäÜ K).range) :
    |(NumberField.discr K : ŌäÜ)| Ōēż 4 * |(a : ŌäÜ)| := by
  classical
  -- The square root also satisfies `x┬▓ = (a : ŌäÜ)` through the `ŌäÜ`-algebra structure.
  have hcast : algebraMap Ōäż K a = algebraMap ŌäÜ K (a : ŌäÜ) := by
    rw [IsScalarTower.algebraMap_apply Ōäż ŌäÜ K, eq_intCast (algebraMap Ōäż ŌäÜ) a]
  have hx2' : x ^ 2 = algebraMap ŌäÜ K (a : ŌäÜ) := hx2.trans hcast
  -- `x ŌēĀ 0`, else `x = algebraMap ŌäÜ K 0` would be rational.
  have hxne : x ŌēĀ 0 := by
    rintro rfl
    exact hx Ō¤©0, by rw [map_zero]Ō¤®
  -- `{1, x}` is linearly independent over `ŌäÜ`: `x` is nonzero and not a `ŌäÜ`-multiple of `1`.
  have hli : LinearIndependent ŌäÜ ![1, x] := by
    rw [linearIndependent_fin2]
    refine Ō¤©by simpa using hxne, ?_Ō¤®
    intro c hc
    simp only [Matrix.cons_val_one, Matrix.cons_val_zero] at hc
    rw [Algebra.smul_def] at hc
    refine hx Ō¤©cŌü╗┬╣, ?_Ō¤®
    rw [map_invŌéĆ]
    exact inv_eq_of_mul_eq_one_right hc
  -- A linearly independent family of `finrank` vectors is a basis.
  have hcard : Fintype.card (Fin 2) = finrank ŌäÜ K := by
    rw [Fintype.card_fin]; exact hfin.symm
  set b := basisOfLinearIndependentOfCardEqFinrank' ![1, x] hli hcard with hb_def
  have hbcoe : Ōćæb = ![1, x] := coe_basisOfLinearIndependentOfCardEqFinrank' _ _ _
  -- The basis consists of algebraic integers: `1` is integral, and `x` is a root of `X┬▓ - a`.
  have hxint : IsIntegral Ōäż x := by
    refine Ō¤©Polynomial.X ^ 2 - Polynomial.C a,
      Polynomial.monic_X_pow_sub_C a (by norm_num), ?_Ō¤®
    rw [Polynomial.evalŌéé_sub, Polynomial.evalŌéé_X_pow, Polynomial.evalŌéé_C, ŌåÉ hx2, sub_self]
  have hb_int : ŌłĆ i, IsIntegral Ōäż (b i) := by
    intro i
    rw [show (b i) = ![1, x] i from by rw [hbcoe]]
    fin_cases i
    ┬Ę simpa using (isIntegral_one : IsIntegral Ōäż (1 : K))
    ┬Ę simpa using hxint
  -- Combine the effective bound with the trace-form evaluation `disc ŌäÜ {1, x} = 4┬Ęa`.
  have hmain := TauCeti.NumberField.abs_discr_le_of_basis_isIntegral b hb_int
  rw [hbcoe, TauCeti.Algebra.discr_one_elem_eq_of_sq_algebraMap hfin hx2' hx] at hmain
  rwa [abs_mul, show |(4 : ŌäÜ)| = 4 by norm_num] at hmain

/-- The integer form of the quadratic discriminant bound: `|d_K| Ōēż 4┬Ę|a|` over `Ōäż`, for a
quadratic field `K` with `x┬▓ = a Ōłł Ōäż` and `x Ōłē ŌäÜ`. -/
theorem abs_discr_le_of_sq_intCast' {K : Type*} [Field K] [NumberField K]
    {x : K} {a : Ōäż} (hfin : finrank ŌäÜ K = 2)
    (hx2 : x ^ 2 = algebraMap Ōäż K a) (hx : x Ōłē (algebraMap ŌäÜ K).range) :
    |NumberField.discr K| Ōēż 4 * |a| := by
  exact_mod_cast abs_discr_le_of_sq_intCast hfin hx2 hx

end NumberField

end TauCeti
